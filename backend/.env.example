# Base de datos - Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# JWT
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_aqui
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN=https://tu-salon.vercel.app

# N8N Integration
N8N_WEBHOOK_URL=https://n8n.yourserver.com/webhook/urban-ladies
N8N_API_KEY=your-n8n-api-key

# Llamadas/Calls API
CALLS_API_URL=https://your-calls-api.com
CALLS_API_KEY=your-calls-api-key

# Appointment Reminders Configuration
REMINDER_CALL_HOUR=18  # Hora del día (0-23) para enviar recordatorios (ej: 18 = 6pm)
REMINDER_RETRY_HOURS=5  # Horas a esperar antes de reintentar si no contesta
MAX_REMINDER_ATTEMPTS=2  # Máximo número de reintentos
